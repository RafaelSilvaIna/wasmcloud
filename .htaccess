Options -Indexes -ExecCGI
ServerSignature Off
DirectoryIndex index.php index.html
AddType application/manifest+json .webmanifest

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-DNS-Prefetch-Control "on"
    Header unset X-Powered-By

    <FilesMatch "\.(?:css|js|mjs|png|jpe?g|gif|webp|svg|ico|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
    </FilesMatch>

    <FilesMatch "^(sw\.js|manifest\.webmanifest)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    <Files "sw.js">
        Header set Service-Worker-Allowed "/"
    </Files>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json text/plain text/html text/css text/javascript application/javascript application/x-javascript image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS application/json text/plain text/html text/css text/javascript application/javascript image/svg+xml
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloqueio de métodos maliciosos e injeções
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|DEBUG)
    RewriteRule .* - [F,L]

    RewriteCond %{QUERY_STRING} (eval\() [NC,OR]
    RewriteCond %{QUERY_STRING} (127\.0\.0\.1) [NC,OR]
    RewriteCond %{QUERY_STRING} \b(union|insert|cast|set|declare|drop|update|md5|benchmark)\b [NC,OR]
    RewriteCond %{QUERY_STRING} \.\./\.\. [NC,OR]
    RewriteCond %{QUERY_STRING} \b(etc/passwd)\b [NC]
    RewriteRule .* - [F,L]

    # Bloqueio de arquivos sensíveis
    RewriteRule ^(\.git|\.env|composer\.json|composer\.lock|package\.json|package-lock\.json) - [F,L]
    RewriteRule ^(config/|security/(config|engine|logger|mitigation|ratelimit|reputation|storage|whitelist)(/.*)?|security/GlobalSecurityLayer\.php) - [F,L]
    
    # Roteamento da API
    RewriteRule ^api/admin/(.*)$ routes/admin/index.php [QSA,L]
    RewriteRule ^api/status/(.*)$ routes/status/index.php [QSA,L]
    RewriteRule ^api/ads/(.*)$ routes/ads/index.php [QSA,L]
    RewriteRule ^api/suporte/(.*)$ routes/suporte/index.php [QSA,L]
    RewriteRule ^api/v2/(.*)$ routes/v2/index.php [QSA,L]
    RewriteRule ^api/v3/(.*)$ routes/v3/index.php [QSA,L]
    RewriteRule ^api/v4/(.*)$ routes/v4/index.php [QSA,L]
    RewriteRule ^cdn/(.*)$ routes/cdn/index.php [QSA,L]

    # Bloqueio de pastas sensíveis
    # Adicionada exceção para permitir o redirecionamento interno para os entrypoints da V2, V3 e V4
    RewriteCond %{REQUEST_URI} !^/routes/v2/index.php
    RewriteCond %{REQUEST_URI} !^/routes/v3/index.php
    RewriteCond %{REQUEST_URI} !^/routes/v4/index.php
    RewriteCond %{REQUEST_URI} !^/routes/admin/index.php
    RewriteCond %{REQUEST_URI} !^/routes/status/index.php
    RewriteCond %{REQUEST_URI} !^/routes/cdn/index.php
    RewriteCond %{REQUEST_URI} !^/routes/suporte/index.php
    RewriteRule ^(components/|controllers/|data/|database/|helpers/|hooks/|models/|routes/|services/|utils/|middleware/)(/.*)?$ - [F,L]

    # Redirecionamento para páginas específicas
    RewriteRule ^ads/?$ pages/ads/index.php [QSA,L]
    RewriteRule ^ads/dashboard/onboarding/?$ pages/ads/index.php?view=dashboard_onboarding [QSA,L]
    RewriteRule ^ads/anuncios/?$ pages/ads/index.php?view=campaigns [QSA,L]
    RewriteRule ^ads/anuncios/status/?$ pages/ads/index.php?view=campaign_status [QSA,L]
    RewriteRule ^ads/anuncios/criar/?$ pages/ads/index.php?view=campaign_create_select [QSA,L]
    RewriteRule ^ads/anuncios/criar/upload/?$ pages/ads/index.php?view=campaign_create_upload [QSA,L]
    RewriteRule ^ads/anuncios/criar/detalhes/?$ pages/ads/index.php?view=campaign_create_details [QSA,L]
    RewriteRule ^ads/anuncios/criar/revisao/?$ pages/ads/index.php?view=campaign_create_review [QSA,L]
    RewriteRule ^ads/([^/]+)/?$ pages/ads/index.php?view=$1 [QSA,L]
    RewriteRule ^suporte/?$ pages/suporte/index.php [QSA,L]
    RewriteRule ^developer/?$ pages/developer/index.php [L]
    RewriteRule ^developer/([^/]+)/?$ pages/developer/index.php?action=$1 [QSA,L]
    RewriteRule ^status/?$ pages/status.php [QSA,L]
    RewriteRule ^home/?$ pages/index.php [L]
    RewriteRule ^login(/.*)?$ pages/index.php [QSA,L]
    RewriteRule ^plan(/.*)?$ pages/index.php [QSA,L]
    RewriteRule ^d2xs8d3sdfsegequ6249f=([A-Za-z0-9_-]+)/?$ pages/d2xs8d3sdfsegequ6249f.php?route=$1 [QSA,L]
    RewriteRule ^d2xs8d3sdfsegequ6249f/?$ pages/d2xs8d3sdfsegequ6249f.php [QSA,L]
    RewriteRule ^error(/.*)?$ pages/error/index.php [QSA,L]
    RewriteRule ^minha-lista/?$ pages/index.php [L]
    RewriteRule ^busca/?$ pages/index.php [L]
    RewriteRule ^view/?$ pages/index.php [L]
    RewriteRule ^player/?$ pages/index.php [L]
    RewriteRule ^info/?$ pages/index.php [L]
    RewriteRule ^plataforma/?$ pages/index.php [L]
    
    # Redirecionamento para a pasta pages (raiz)
    RewriteRule ^$ pages/index.php [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/pages/
    RewriteCond %{REQUEST_URI} !^/assets/
    RewriteRule ^(.*)$ pages/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^pages/(.*)$ pages/index.php [QSA,L]
</IfModule>
